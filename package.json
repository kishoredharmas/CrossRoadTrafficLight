{
  "name": "traffic-light-simulation",
  "version": "1.0.0",
  "description": "Advanced traffic light simulation with real-time visualization and algorithm testing",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon --delay 2 server/index.js",
    "dev:debug": "nodemon --delay 2 --inspect server/index.js",
    "client": "cd client && npm start",
    "dev:full": "concurrently --kill-others --kill-others-on-fail \"npm run dev\" \"npm run client\"",
    "dev:full:debug": "concurrently --kill-others --kill-others-on-fail \"npm run dev:debug\" \"npm run client\"",
    "postinstall": "cd client && npm install",
    "build": "cd client && npm run build",
    "test": "jest",
    "install-all": "npm install && cd client && npm install",
    "migrate": "node server/scripts/migrateDataToDatabase.js",
    "migrate:session": "node server/scripts/alterSessionTable.js",
    "test:db": "node server/scripts/testDatabase.js"
  },
  "keywords": [
    "traffic",
    "simulation",
    "traffic-light",
    "algorithm",
    "visualization"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": "18.x",
    "npm": "9.x"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
